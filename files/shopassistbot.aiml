<aiml version="1.0.1" encoding="UTF-8">
    <category>
        <pattern>HELLO</pattern>
        <template>Hi! 👋 I'm your assistant. Try: 'I want electronics' or 'Show categories'.</template>
    </category>

    <category>
        <pattern>SHOW CATEGORIES</pattern>
        <template>We have: Electronics, Apparel, Footwear, Books, and Home Appliances.</template>
    </category>

    <category>
        <pattern>I WANT ELECTRONICS</pattern>
        <template>
            <think><set name="category">Electronics</set></think>
            Great! What is your budget for Electronics?
        </template>
    </category>

    <category>
        <pattern>I WANT *</pattern>
        <template>
            <think><set name="category"><star/></set></think>
            What is your budget for <star/>?
        </template>
    </category>
</aiml>
