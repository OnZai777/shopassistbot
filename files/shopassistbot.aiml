<?xml version="1.0" encoding="UTF-8"?>
<aiml version="1.0.1" encoding="UTF-8">

<category>
    <pattern>HELLO</pattern>
    <template>
        Hey there! 👋 Welcome! [cite: 2] Try:
        - I want electronics
        - Show categories
    </template>
</category>

<category><pattern>HI</pattern><template><srai>HELLO</srai></template></category>
<category><pattern>HEY</pattern><template><srai>HELLO</srai></template></category>

<category>
    <pattern>SHOW CATEGORIES</pattern>
    <template>
        We have: Electronics, Books, Apparel, and Footwear. Which one do you prefer?
    </template>
</category>

<category>
    <pattern>I WANT ELECTRONICS</pattern>
    <template>
        <think><set name="category">ELECTRONICS</set></think>
        Great! What's your budget for Electronics? [cite: 3]
    </template>
</category>

<category>
    <pattern>I WANT BOOKS</pattern>
    <template>
        <think><set name="category">BOOKS</set></think>
        Nice! What's your budget for Books? [cite: 4]
    </template>
</category>

<category>
    <pattern>I WANT APPAREL</pattern>
    <template>
        <think><set name="category">APPAREL</set></think>
        Good choice! What's your budget for Apparel? [cite: 5]
    </template>
</category>

<category>
    <pattern>I WANT FOOTWEAR</pattern>
    <template>
        <think><set name="category">FOOTWEAR</set></think>
        Nice! What's your budget for Footwear? [cite: 6]
    </template>
</category>

<category>
    <pattern>I WANT *</pattern>
    <template>
        I'm sorry, I don't have recommendations for that yet. Please choose: Electronics, Books, Apparel, or Footwear.
    </template>
</category>

</aiml>
