<?xml version="1.0" encoding="UTF-8"?>
<aiml version="1.0.1" encoding="UTF-8">

<category>
    <pattern>HELLO</pattern>
    <template>
        Hi there! 👋 Welcome to ShopAssist. I can recommend products from our catalog. 
        You can ask to "Show categories" or tell me what you're looking for (e.g., "I want books").
    </template>
</category>

<category><pattern>HI</pattern><template><srai>HELLO</srai></template></category>
<category><pattern>HEY</pattern><template><srai>HELLO</srai></template></category>

<category>
    <pattern>SHOW CATEGORIES</pattern>
    <template>
        We currently have the following categories available:
        • Electronics 📱
        • Apparel 👕
        • Footwear 👟
        • Books 📚
        • Home Appliances 🏠
        Which one are you interested in?
    </template>
</category>

<category><pattern>WHAT CATEGORIES *</pattern><template><srai>SHOW CATEGORIES</srai></template></category>
<category><pattern>LIST CATEGORIES</pattern><template><srai>SHOW CATEGORIES</srai></template></category>

<category>
    <pattern>I WANT ELECTRONICS</pattern>
    <template>
        <think><set name="category">Electronics</set></think>
        Excellent choice. 📱 What is your maximum budget for Electronics?
    </template>
</category>

<category>
    <pattern>I WANT APPAREL</pattern>
    <template>
        <think><set name="category">Apparel</set></think>
        Great! 👕 What is your budget for Apparel items?
    </template>
</category>

<category>
    <pattern>I WANT FOOTWEAR</pattern>
    <template>
        <think><set name="category">Footwear</set></think>
        Nice! 👟 How much are you looking to spend on Footwear?
    </template>
</category>

<category>
    <pattern>I WANT BOOKS</pattern>
    <template>
        <think><set name="category">Books</set></think>
        Books are a great choice! 📚 What is your budget?
    </template>
</category>

<category>
    <pattern>I WANT HOME APPLIANCES</pattern>
    <template>
        <think><set name="category">Home Appliances</set></think>
        Home Appliances, understood! 🏠 What is your budget for this category?
    </template>
</category>

<category>
    <pattern>I WANT *</pattern>
    <template>
        I'm sorry, I don't have information on "<star/>" yet. 
        I can help you with Electronics, Apparel, Footwear, Books, or Home Appliances!
    </template>
</category>

</aiml>
